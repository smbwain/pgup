{
  "compilerOptions": {
    "module": "Node16",
    "target": "ES2017",
    "noImplicitAny": true,
    "moduleResolution": "node16",
    "outDir": "dist",
    "sourceMap": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "rootDir": "src",
    "declaration": true,
    "strictNullChecks": true,
    "paths": {
      "*": ["./src/*"]
    }
  },
  "include": ["src/**/*"]
}
